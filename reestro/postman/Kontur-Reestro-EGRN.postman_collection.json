      "name": "0. \u0421\u043b\u0443\u0436\u0435\u0431\u043d\u044b\u0435 (\u0430\u0432\u0442\u043e\u0440\u0438\u0437\u0430\u0446\u0438\u044f \u0438 \u0431\u0430\u043b\u0430\u043d\u0441)",
      "item": [
        {
          "name": "\u041f\u0440\u043e\u0432\u0435\u0440\u043a\u0430 \u0430\u0432\u0442\u043e\u0440\u0438\u0437\u0430\u0446\u0438\u0438",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// \u041f\u0440\u043e\u0432\u0435\u0440\u043a\u0430 \u0430\u0432\u0442\u043e\u0440\u0438\u0437\u0430\u0446\u0438\u0438: \u0434\u0451\u0448\u0435\u0432\u043e \u0431\u044c\u0451\u043c \u043f\u043e \u0441\u0432\u043e\u0434\u043a\u0435 \u0431\u0430\u043b\u0430\u043d\u0441\u0430 (\u0431\u0435\u0437 \u043f\u043b\u0430\u0442\u043d\u044b\u0445 \u0437\u0430\u043f\u0440\u043e\u0441\u043e\u0432 \u043a \u0415\u0413\u0420\u041d).",
                  "if (pm.response.code === 401 || pm.response.code === 403) {",
                  "    pm.test('\u0410\u0432\u0442\u043e\u0440\u0438\u0437\u0430\u0446\u0438\u044f \u041d\u0415 \u043f\u0440\u043e\u0439\u0434\u0435\u043d\u0430 \u2014 \u043f\u0440\u043e\u0432\u0435\u0440\u044c\u0442\u0435 apiKey \u0438 orgId \u0432 \u043e\u043a\u0440\u0443\u0436\u0435\u043d\u0438\u0438', function () {",
                  "        pm.expect.fail('HTTP ' + pm.response.code + ': \u0434\u043e\u0441\u0442\u0443\u043f \u0437\u0430\u043f\u0440\u0435\u0449\u0451\u043d');",
                  "    });",
                  "} else {",
                  "    pm.test('\u0410\u0432\u0442\u043e\u0440\u0438\u0437\u0430\u0446\u0438\u044f \u0443\u0441\u043f\u0435\u0448\u043d\u0430 (HTTP 200)', function () {",
                  "        pm.response.to.have.status(200);",
                  "    });",
                  "    console.log('\u0410\u0432\u0442\u043e\u0440\u0438\u0437\u0430\u0446\u0438\u044f \u0443\u0441\u043f\u0435\u0448\u043d\u0430. apiKey \u0438 orgId \u043f\u0440\u0438\u043d\u044f\u0442\u044b \u0441\u0435\u0440\u0432\u0435\u0440\u043e\u043c.');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/realty/billing/v1/balance",
