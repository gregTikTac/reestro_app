              ]
            },
            "description": "\u041f\u0440\u043e\u0432\u0435\u0440\u043a\u0430 \u043a\u043e\u0440\u0440\u0435\u043a\u0442\u043d\u043e\u0441\u0442\u0438 \u0430\u0432\u0442\u043e\u0440\u0438\u0437\u0430\u0446\u0438\u0438 (apiKey + orgId). \u0418\u0441\u043f\u043e\u043b\u044c\u0437\u0443\u0435\u0442\u0441\u044f \u043b\u0451\u0433\u043a\u0438\u0439 \u0431\u0435\u0441\u043f\u043b\u0430\u0442\u043d\u044b\u0439 \u043c\u0435\u0442\u043e\u0434 \u0441\u0432\u043e\u0434\u043a\u0438 \u043f\u043e \u0431\u0430\u043b\u0430\u043d\u0441\u0443. HTTP 200 \u2014 \u0430\u0432\u0442\u043e\u0440\u0438\u0437\u0430\u0446\u0438\u044f \u043f\u0440\u0438\u043d\u044f\u0442\u0430; 401/403 \u2014 \u043a\u043b\u044e\u0447 \u0438\u043b\u0438 \u0438\u0434\u0435\u043d\u0442\u0438\u0444\u0438\u043a\u0430\u0442\u043e\u0440 \u043e\u0440\u0433\u0430\u043d\u0438\u0437\u0430\u0446\u0438\u0438 \u043d\u0435\u0432\u0435\u0440\u043d\u044b."
          },
          "response": []
        },
        {
          "name": "\u041f\u0440\u043e\u0432\u0435\u0440\u043a\u0430 \u0431\u0430\u043b\u0430\u043d\u0441\u0430",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('\u0421\u0442\u0430\u0442\u0443\u0441 200 OK', function () { pm.response.to.have.status(200); });",
                  "pm.test('\u041e\u0442\u0432\u0435\u0442 \u0432 \u0444\u043e\u0440\u043c\u0430\u0442\u0435 JSON', function () { pm.response.to.be.json; });",
                  "",
                  "var data = pm.response.json();",
                  "var items = (data && data.items) || [];",
                  "",
                  "pm.test('\u041f\u043e\u043b\u0443\u0447\u0435\u043d\u0430 \u0441\u0432\u043e\u0434\u043a\u0430 \u043f\u043e \u0431\u0430\u043b\u0430\u043d\u0441\u0443', function () {",
                  "    pm.expect(items.length, '\u043d\u0435\u0442 \u0443\u0441\u043b\u0443\u0433 \u0432 \u043e\u0442\u0432\u0435\u0442\u0435').to.be.above(0);",
                  "});",
                  "",
                  "function human(s) {",
                  "    var b = s.balance || {};",
                  "    var val = b.value;",
                  "    var unit = b.unit || b.unitClass || '';",
                  "    var amount = (unit === 'Kopek')",
                  "        ? (Number(val) / 100).toFixed(2) + ' \u0440\u0443\u0431.'",
                  "        : (val + ' \u0448\u0442.');",
                  "    var name = (s.type && (s.type.description || s.type.code)) || s.id;",
                  "    var tariff = s.tariffType ? ' [' + s.tariffType + ']' : '';",
                  "    return name + ': ' + amount + tariff;",
                  "}",
                  "",
                  "var lines = items.map(human);",
                  "console.log('\u0411\u0430\u043b\u0430\u043d\u0441 \u043f\u043e \u0443\u0441\u043b\u0443\u0433\u0430\u043c:\\n' + lines.join('\\n'));",
                  "pm.visualizer.set('<h3>\u0411\u0430\u043b\u0430\u043d\u0441 \u043f\u043e \u0443\u0441\u043b\u0443\u0433\u0430\u043c</h3><ul>{{#each rows}}<li>{{this}}</li>{{/each}}</ul>', { rows: lines });"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
